{
  "name": "codeflow",
  "owner": {
    "name": "Aakash Kumar",
    "url": "https://github.com/RTinkslinger"
  },
  "metadata": {
    "description": "Live-updating module dependency graphs for polyglot codebases",
    "version": "0.1.18",
    "pluginRoot": "./"
  },
  "plugins": [
    {
      "name": "codeflow",
      "description": "Live-updating module dependency flowcharts for polyglot codebases. Type /flow to open a live browser diagram.",
      "version": "0.1.18",
      "source": "./",
      "author": {
        "name": "Aakash Kumar"
      },
      "repository": "https://github.com/RTinkslinger/codeflow",
      "license": "MIT",
      "keywords": ["codeflow", "flowchart", "dependency-graph", "typescript", "python", "visualization"],
      "mcpServers": {
        "codeflow": {
          "command": "node",
          "args": ["${CLAUDE_PLUGIN_ROOT}/packages/cli/dist/main.js"]
        }
      }
    }
  ]
}
