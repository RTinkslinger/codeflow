{
  "name": "codeflow",
  "private": true,
  "version": "0.1.6",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r run build",
    "build:plugin": "tsx scripts/build-plugin.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "pnpm -r exec tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "fast-check": "^3.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "tree-sitter",
      "tree-sitter-python"
    ]
  }
}
